rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to validate document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate configuration fields
    function isValidConfig(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.tagline is string && data.tagline.size() <= 200
          && data.adminPin is string && data.adminPin.size() >= 4 && data.adminPin.size() <= 10
          && data.whatsappNumber is string && data.whatsappNumber.size() >= 10 && data.whatsappNumber.size() <= 15
          && data.deliveryCharge is number && data.deliveryCharge >= 0
          && data.minOrder is number && data.minOrder >= 0;
    }

    // Helper to validate category fields
    function isValidCategory(data, categoryId) {
      return isValidId(categoryId)
          && data.id == categoryId
          && data.label is string && data.label.size() > 0 && data.label.size() <= 100;
    }

    // Helper to validate menu item fields
    function isValidMenuItem(data, menuItemId) {
      return isValidId(menuItemId)
          && data.id == menuItemId
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && (!('desc' in data) || (data.desc is string && data.desc.size() <= 500))
          && data.cat is string && data.cat.size() <= 128
          && data.price is number && data.price > 0
          && data.popular is bool
          && (!('outOfStock' in data) || data.outOfStock is bool);
    }

    // Helper to validate order fields
    function isValidOrder(data, orderId) {
      return isValidId(orderId)
          && data.id == orderId
          && data.total is number && data.total >= 0
          && data.deliveryCharge is number && data.deliveryCharge >= 0
          && data.status is string && (
               data.status == 'new' || 
               data.status == 'accepted' || 
               data.status == 'preparing' || 
               data.status == 'ready' || 
               data.status == 'delivered' || 
               data.status == 'cancelled'
             )
          && data.time is string;
    }

    // --- MATCH BLOCKS ---
    
    // Configs collection
    match /configs/kitchen {
      allow read: if true;
      allow write: if isValidConfig(request.resource.data);
    }

    // Categories catalog
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isValidCategory(request.resource.data, categoryId);
      allow delete: if true;
    }

    // Menu catalog
    match /menu/{menuItemId} {
      allow read: if true;
      allow write: if isValidMenuItem(request.resource.data, menuItemId);
      allow delete: if true;
    }

    // Orders transaction log
    match /orders/{orderId} {
      allow read: if true;
      allow create: if isValidOrder(request.resource.data, orderId);
      allow update: if isValidOrder(request.resource.data, orderId);
      allow delete: if true;
    }

  }
}
